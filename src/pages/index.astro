---
import BaseLayout from "../layouts/BaseLayout.astro";
import pillars from "../data/pillars.json";
import siteContent from "../data/site-content.json";

const homeContent = siteContent.home;
const heroTitleParts = homeContent.hero.title.split(homeContent.hero.emphasis ?? "");
const heroStats = homeContent.vision.stats.map((stat) => ({
  ...stat,
  resolvedValue: stat.value === "{pillars.length}" ? String(pillars.length) : stat.value
}));
const iconPaths = {
  "skills-framework": [
    "M10 8h12",
    "M8 12h16",
    "M11 16h10",
    "M9 8v10",
    "M15 12v10"
  ],
  "learning-structure-landscape": [
    "M6 8h12l4 4-4 4H6z",
    "M6 12h16",
    "M10 16h10"
  ],
  "assessment-validation": [
    "M7 13l4 4 9-10",
    "M12 4a8 8 0 1 1 0 16a8 8 0 0 1 0-16z"
  ],
  "manager-involvement": [
    "M8 10a2.5 2.5 0 1 0 0-.01",
    "M16 9a2 2 0 1 0 0-.01",
    "M4.5 18c.8-2.7 2.8-4 5.5-4s4.7 1.3 5.5 4",
    "M13.5 18c.5-1.8 1.8-2.8 3.8-2.8 1 0 1.9.2 2.7.7"
  ],
  "social-learning": [
    "M12 20s-7-4.4-7-9.6A4.4 4.4 0 0 1 9.4 6c1.1 0 2.1.4 2.6 1.2C12.5 6.4 13.5 6 14.6 6A4.4 4.4 0 0 1 19 10.4C19 15.6 12 20 12 20z"
  ],
  "learning-support": [
    "M12 5l1.8 3.7 4.2.6-3 2.9.7 4.2-3.7-2-3.7 2 .7-4.2-3-2.9 4.2-.6z",
    "M12 14v5"
  ],
  "structure-processes": [
    "M6 18V8l3-2 3 2v10",
    "M12 18V6l3-2 3 2v12",
    "M4 18h16"
  ]
};
---

<BaseLayout title={homeContent.pageTitle}>
  <section class="hero-wrap">
    <div class="hero-grid">
      <div class="hero-left">
        <p class="kicker">{homeContent.hero.kicker}</p>
        <h1>
          {heroTitleParts[0]}
          {homeContent.hero.emphasis && <em>{homeContent.hero.emphasis}</em>}
          {heroTitleParts[1]}
        </h1>
        <p class="lead">{homeContent.hero.lead}</p>
        <a class="cta" href={homeContent.hero.ctaHref}>{homeContent.hero.ctaLabel}</a>
      </div>
      <aside class="vision-card">
        <p class="kicker">{homeContent.vision.kicker}</p>
        <p class="vision-quote">{homeContent.vision.quote}</p>
        <div class="stats">
          {
            heroStats.map((stat) => (
              <div>
                <strong>{stat.resolvedValue}</strong>
                <span>{stat.label}</span>
              </div>
            ))
          }
        </div>
      </aside>
    </div>
  </section>

  <section id={homeContent.framework.sectionId} class="framework-wrap">
    <div class="framework-head">
      <p class="kicker dark">{homeContent.framework.kicker}</p>
      <h2>
        {homeContent.framework.titleLine1}<br />{homeContent.framework.titleLine2}
      </h2>
      <p>{homeContent.framework.description}</p>
    </div>
    <div class="pillar-grid">
      {
        pillars.map((pillar, index) => (
          <article class="pillar-card">
            <div class="icon-row">
              <span class={`icon ${pillar.accent}`} aria-hidden="true">
                <svg viewBox="0 0 24 24" role="img" focusable="false">
                  {
                    (iconPaths[pillar.slug] ?? []).map((path) => (
                      <path d={path}></path>
                    ))
                  }
                </svg>
              </span>
              <span class="ghost-nr">{index + 1}</span>
            </div>
            <h3>{pillar.title}</h3>
            <p>{pillar.cardDescription}</p>
            <a href={`/pillars/${pillar.slug}`}>{homeContent.framework.linkLabel}</a>
          </article>
        ))
      }
    </div>
  </section>
</BaseLayout>

<style>
  .hero-wrap {
    color: #eaf0f5;
    padding: 4rem 1.25rem 6rem;
    background:
      radial-gradient(circle at 18% 100%, rgba(21, 96, 130, 0.26), transparent 45%),
      radial-gradient(circle at 85% 5%, rgba(255, 255, 255, 0.08), transparent 38%),
      radial-gradient(rgba(255, 255, 255, 0.08) 1px, transparent 1px),
      var(--brand-navy);
    background-size: auto, auto, 16px 16px, auto;
  }

  .hero-grid {
    max-width: 1220px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 2.25rem;
    align-items: start;
  }

  .kicker {
    margin: 0 0 1rem;
    letter-spacing: 0.18em;
    font-size: 0.72rem;
    color: #95a8bb;
    font-weight: 650;
    text-transform: uppercase;
  }

  .hero-left h1 {
    margin: 0;
    max-width: 16ch;
    line-height: 0.92;
    letter-spacing: -0.035em;
    font-size: clamp(2.35rem, 5vw, 5rem);
    color: #f4f7fb;
    font-family: var(--font-display);
    font-weight: 700;
  }

  .hero-left em {
    color: #d7e0ea;
    font-style: italic;
    font-weight: 450;
  }

  .lead {
    margin: 1.5rem 0 2rem;
    max-width: 56ch;
    line-height: 1.68;
    color: #c5d1dd;
    font-size: 1rem;
  }

  .cta {
    display: inline-block;
    text-decoration: none;
    background: #f3f4f5;
    color: #132f48;
    padding: 0.86rem 1.3rem;
    border-radius: 0.2rem;
    font-weight: 700;
    border: 1px solid #f3f4f5;
    transition: 0.2s ease;
  }

  .cta:hover {
    transform: translateY(-1px);
    background: transparent;
    color: #f3f4f5;
  }

  .vision-card {
    border: 1px solid rgba(232, 237, 245, 0.2);
    border-radius: 0.6rem;
    padding: 1.9rem;
    background: rgba(255, 255, 255, 0.03);
  }

  .vision-quote {
    margin: 0;
    font-size: clamp(1.22rem, 2vw, 1.8rem);
    line-height: 1.42;
    letter-spacing: -0.015em;
    color: #dce5ee;
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 500;
  }

  .stats {
    margin-top: 2.2rem;
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
    border-top: 1px solid rgba(232, 237, 245, 0.14);
    padding-top: 1rem;
  }

  .stats strong {
    display: block;
    color: #d5ae75;
    font-size: 1.9rem;
    font-family: var(--font-display);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1;
  }

  .stats span {
    font-size: 0.88rem;
    color: #b2c2d1;
  }

  .framework-wrap {
    max-width: 1260px;
    margin: 0 auto;
    padding: 3.7rem 1.25rem 4.2rem;
  }

  .framework-head h2 {
    margin: 0;
    line-height: 0.94;
    letter-spacing: -0.03em;
    font-size: clamp(2.1rem, 3.8vw, 3.85rem);
    font-family: var(--font-display);
    font-weight: 700;
  }

  .framework-head p {
    margin: 1rem 0 2.1rem;
    max-width: 58ch;
    color: var(--muted);
    font-size: 1.08rem;
    line-height: 1.7;
  }

  .kicker.dark {
    color: #97a1ab;
  }

  .pillar-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }

  .pillar-card {
    border: 1px solid var(--stroke);
    border-radius: 0.45rem;
    background: #f8f8f7;
    padding: 1.4rem;
    display: flex;
    flex-direction: column;
    min-height: 16rem;
  }

  .icon-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.65rem;
  }

  .icon {
    width: 2.1rem;
    height: 2.1rem;
    border-radius: 0.45rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: #53565a;
    background: rgba(83, 86, 90, 0.08);
    border: 1px solid rgba(83, 86, 90, 0.16);
  }

  .icon svg {
    width: 1.4rem;
    height: 1.4rem;
    stroke: currentColor;
    fill: none;
    stroke-width: 1.65;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .icon.green {
    color: #53565a;
    background: rgba(25, 107, 36, 0.1);
  }

  .icon.orange {
    color: #53565a;
    background: rgba(233, 113, 50, 0.1);
  }

  .icon.purple {
    color: #53565a;
    background: rgba(160, 43, 147, 0.08);
  }

  .icon.teal {
    color: #53565a;
    background: rgba(21, 96, 130, 0.1);
  }

  .ghost-nr {
    color: #ececeb;
    font-size: 2.8rem;
    line-height: 1;
    font-family: var(--font-display);
    font-weight: 600;
    letter-spacing: -0.04em;
  }

  .pillar-card h3 {
    margin: 0.25rem 0 0.5rem;
    font-family: var(--font-display);
    font-size: 1.75rem;
    line-height: 1;
    letter-spacing: -0.03em;
    font-weight: 700;
  }

  .pillar-card p {
    margin: 0;
    color: #4b5864;
    line-height: 1.68;
  }

  .pillar-card a {
    margin-top: auto;
    padding-top: 1rem;
    color: var(--brand-teal);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    text-decoration: none;
    font-size: 0.74rem;
    font-weight: 700;
  }

  .pillar-card a:hover {
    text-decoration: underline;
  }

  @media (max-width: 1080px) {
    .hero-grid {
      grid-template-columns: 1fr;
    }

    .hero-left h1 {
      max-width: 19ch;
    }

    .pillar-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 760px) {
    .hero-wrap {
      padding-top: 3rem;
      padding-bottom: 4rem;
    }

    .pillar-grid {
      grid-template-columns: 1fr;
    }

    .framework-head p {
      font-size: 1rem;
    }
  }
</style>
